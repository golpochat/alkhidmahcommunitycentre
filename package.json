{
  "name": "al-khidmah-mosque",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/prisma-with-env.mjs generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "node scripts/prisma-with-env.mjs generate",
    "prisma": "node scripts/prisma-with-env.mjs",
    "db:push": "node scripts/prisma-with-env.mjs db push",
    "db:push:force": "node scripts/prisma-with-env.mjs db push --accept-data-loss",
    "db:deploy": "node scripts/prisma-with-env.mjs migrate deploy",
    "db:resolve-applied": "node scripts/prisma-with-env.mjs migrate resolve --applied",
    "db:baseline": "node scripts/baseline-prisma-migrations.mjs",
    "db:migrate-email": "dotenv -e .env.local -- npx tsx scripts/migrate-email-settings-to-smtp.ts",
    "db:migrate-payment": "dotenv -e .env.local -- npx tsx scripts/migrate-payment-gateways.ts",
    "db:migrate-rbac": "dotenv -e .env.local -- npx tsx scripts/migrate-rbac.ts",
    "db:seed": "dotenv -e .env.local -- npx tsx prisma/seed.ts",
    "db:test-users": "dotenv -e .env.local -- npx tsx scripts/create-test-users.ts",
    "db:seed-donations-sample": "dotenv -e .env.local -- npx tsx scripts/seed-sample-donations.ts",
    "db:clear-donations-sample": "dotenv -e .env.local -- npx tsx scripts/clear-sample-donations.ts",
    "db:seed-donation-categories": "dotenv -e .env.local -- npx tsx scripts/seed-donation-categories.ts",
    "db:fix-super-admin": "dotenv -e .env.local -- npx tsx scripts/ensure-single-super-admin.ts",
    "fonts:setup-flyer": "node scripts/setup-flyer-fonts.mjs",
    "stripe:verify": "dotenv -e .env.local -- npx tsx scripts/verify-stripe-settings.ts",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/donations/stripe/webhook",
    "db:migrate": "node scripts/prisma-with-env.mjs migrate dev",
    "db:studio": "node scripts/prisma-with-env.mjs studio",
    "db:fix-pooler": "node scripts/fix-neon-pooler-env.mjs",
    "images:setup": "node scripts/setup-local-images.mjs",
    "images:refresh": "node scripts/setup-local-images.mjs --force"
  },
  "prisma": {
    "seed": "dotenv -e .env.local -- npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^5.22.0",
    "@stripe/react-stripe-js": "^6.5.0",
    "@stripe/stripe-js": "^9.7.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.17.0",
    "next": "14.2.35",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.10",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "react": "^18",
    "react-day-picker": "^10.0.1",
    "react-dom": "^18",
    "react-hook-form": "^7.76.1",
    "recharts": "^3.8.1",
    "satori": "^0.26.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.8.3",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "stripe": "^22.2.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.21.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/ws": "^8.18.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
