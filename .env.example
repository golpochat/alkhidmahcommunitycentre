# Al Khidmah Community Centre — Environment Variables

# ─── Site ───────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CHARITY_NUMBER=CHY 22345

# ─── Database (PostgreSQL — Neon / Supabase / DigitalOcean) ─
# Put secrets in .env.local (Next.js + npm db scripts load it automatically).
# Do NOT run `npx prisma ...` directly — use npm scripts instead:
#   npm run db:push
#   npm run db:deploy
#   npm run db:migrate
#   npm run db:studio
#   npm run prisma -- studio
#
# Neon: use the **pooler** host for DATABASE_URL (app runtime).
# Add pgbouncer=true for Prisma with Neon's pooler (transaction mode).
# DIRECT_URL is optional — npm db scripts derive it from DATABASE_URL when needed.
#
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15
# DIRECT_URL=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15

# ─── Authentication ─────────────────────────────────────
JWT_SECRET=your-secure-jwt-secret-min-32-chars
SETTINGS_ENCRYPTION_KEY=your-settings-encryption-key-min-32-chars
ADMIN_EMAIL=super-admin@alkhidmah.ie
ADMIN_PASSWORD=SuperAdmin2026!

# ─── Email (Nodemailer / SMTP) ──────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=ziyaratltd@gmail.com
CONTACT_EMAIL=ziyaratltd@gmail.com

# ─── Stripe (optional — configure in Super Admin → Settings → Payment) ─
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── PayPal (optional — configure in Super Admin → Settings → Payment) ─
# NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id
# PAYPAL_CLIENT_SECRET=your-paypal-client-secret
# PAYPAL_MODE=sandbox

# ─── AlAdhan (prayer times — no key required) ───────────
# Coordinates configured in src/lib/constants.ts

# ─── Setup Commands ─────────────────────────────────────
# npm install
# npm run db:push          # apply schema (uses .env.local)
# npm run db:deploy        # apply migrations (uses .env.local)
# npm run db:migrate-rbac  # only if upgrading DB that had the old Role enum
# npm run db:seed
# npm run dev

# ─── Deployment (Vercel / DigitalOcean) ─────────────────
# 1. Create PostgreSQL database (Neon or Supabase recommended)
# 2. Add all env vars above to your hosting platform
# 3. Run: npm run db:push && npm run db:seed
# 4. Configure Stripe webhook in Super Admin → Payment, or use Stripe CLI locally:
#    stripe listen --forward-to localhost:3000/api/donations/stripe/webhook
# 5. Deploy — verify build with: npm run build
